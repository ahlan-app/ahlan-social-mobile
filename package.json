{
  "name": "ahlan-social-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "description": "A modern social media mobile application built with Expo.",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web:build": "rm -rf dist && mkdir -p dist/client && esbuild index.tsx --bundle --minify --sourcemap --outfile=dist/client/index.js && cp index.html manifest.json service-worker.js icon.svg _redirects dist/client/"
  },
  "dependencies": {
    "@expo-google-fonts/anton": "^0.4.2",
    "@expo-google-fonts/dancing-script": "^0.4.2",
    "@expo-google-fonts/fredoka": "^0.4.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.43.4",
    "date-fns": "^3.6.0",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-media-library": "~18.2.1",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  },
  "private": true
}
